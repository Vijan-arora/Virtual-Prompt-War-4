# Gemini API key. In production this is set as a Render environment variable
# (never stored in the repo or the container image).
GEMINI_API_KEY=your-gemini-api-key

# Gemini model used for the fan assistant and operations briefings.
GEMINI_MODEL=gemini-2.5-flash

# HTTP port the server listens on. Render injects this automatically.
PORT=8080

# Comma-separated list of origins allowed by CORS (the deployed app is
# same-origin, so this only matters for local cross-origin development).
ALLOWED_ORIGINS=http://localhost:5173

# GCP project that hosts Firestore. Set this to your own GCP project ID.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# pino log level: debug | info | warn | error
LOG_LEVEL=info

# Set to "false" to disable the crowd-telemetry simulator loop.
TELEMETRY_SIM_ENABLED=true

# Set to "true" to use in-memory database simulation for local development.
USE_FAKE_FIRESTORE=true

