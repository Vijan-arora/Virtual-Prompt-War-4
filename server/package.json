{
  "name": "@arenaflow/server",
  "version": "1.0.0",
  "description": "ArenaFlow API — Gemini-powered multilingual fan assistant and stadium operations intelligence on Firestore.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=../.env --import=tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google/genai": "^2.11.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.3.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^7.1.0",
    "tsx": "^4.20.0",
    "vitest": "^4.1.10"
  }
}
